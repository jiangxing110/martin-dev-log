@Slf4j
@Validated
@RestController
@RequestMapping("open-api/v3/statements")
@Tag(name = "日账单", description = "子账户日账单查询与导出")
public class DailyStatementController {

    @Resource
    private DailyStatementService dailyStatementService;

    @GetMapping("/xlsx")
    @Operation(summary = "导出 XLSX（余额汇总+交易流水双 Sheet）", operationId = "exportXlsx")
    @NoAuth(NoAuth.OPENAPI)
    public ApiResult<String> exportXlsx(@ParameterObject @Valid StatementExportReqDTO dto) {
        if (!dailyStatementService.hasTransactions(dto.getAccountId(), dto.getDate())) {
            return ApiResult.fail("10003", "no transactions on the specified date");
        }
        String fileUrl = dailyStatementService.exportXlsx(dto.getAccountId(), dto.getDate());
        return ApiResult.ok(fileUrl);
    }

    @PostMapping("/{accountId}/{date}/regenerate")
    @Operation(summary = "异步重新生成账单", operationId = "regenerateStatement")
    @NoAuth(NoAuth.OPENAPI)
    public ApiResult<Map<String, String>> regenerate(
            @PathVariable String accountId,
            @PathVariable String date,
            @RequestBody(required = false) Map<String, Boolean> body) {
        Boolean notify = body != null ? body.getOrDefault("notify", false) : false;
        String taskId = dailyStatementService.regenerate(accountId, date, notify);
        Map<String, String> result = new HashMap<>();
        result.put("task_id", taskId);
        result.put("status", "processing");
        return ApiResult.ok(result);
    }

    @GetMapping("/tasks/{taskId}")
    @Operation(summary = "重新生成进度查询", operationId = "getRegenerateProgress")
    @NoAuth(NoAuth.OPENAPI)
    public ApiResult<TaskProgressRespVO> getRegenerateProgress(@PathVariable String taskId) {
        TaskProgressRespVO result = dailyStatementService.getRegenerateProgress(taskId);
        return ApiResult.ok(result);
    }
}
