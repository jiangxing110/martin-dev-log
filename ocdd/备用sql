SELECT
    au."accountId",
    u.phone
FROM "accountUser" au
INNER JOIN "user" u
    ON au."userId"::UUID = u.id::UUID
   AND u."userType" = 'Master'
INNER JOIN "oddAccountReview" oar
    ON oar."accountId"::UUID = au."accountId"::UUID
   AND oar."deleteTime" IS NULL
   AND oar."accountId" != 'cb8e047f-7836-407a-b732-f5ebd2203622'
LEFT JOIN "accountExtend" ae
    ON au."accountId"::UUID = ae."accountId"::UUID
LEFT JOIN "account" a
    ON a."id"::UUID = ae."accountId"::UUID
   AND a.status IN ('Active')
WHERE u."password" = '4c9db0041bc651f65796b073cbe7947c4a1fab92d633b39f00e3fa042607d4e9'
GROUP BY
    au."accountId",
    u.phone,
    oar."createTime"
ORDER BY
    oar."createTime" DESC;
		
