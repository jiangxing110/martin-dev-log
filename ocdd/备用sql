SELECT ae."accountId"
FROM "CddCompanyBusinessInformation" as cbi
INNER JOIN "cddKyc" ck ON ck."id" = cbi."kycId"
INNER JOIN "accountExtend" as ae ON ck."accountId"::UUID=ae."accountId"::UUID
INNER JOIN "account" as a ON a."id"::UUID=ae."accountId"::UUID
WHERE NOT EXISTS (
    SELECT 1
    FROM "oddAccountReview" oar
    WHERE oar."accountId"::UUID = ck."accountId"::UUID
)
and ae."systemType"='QBIT' and a.status='Active'
and a."accountType"='Business'
and a.type='Merchant' 
GROUP BY ae."accountId"

