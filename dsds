  private List<ApiClientFeeDTO> systemFeeByProvider(QbitCardTransaction data) {
        QbitCardOnlineProviderEnum providerEnum = this.resolveOnlineProvider(data.getProvider());
        if (providerEnum == QbitCardOnlineProviderEnum.IQ) {
            if (data.getBusinessType() == QbitCardTransactionTypeEnum.System_Fee) {
                return this.systemFee(data);
            }
            return List.of();
        }
        if (providerEnum == QbitCardOnlineProviderEnum.BZ) {
            return this.bzSchemeFee(data);
        }
        return List.of();
    }

