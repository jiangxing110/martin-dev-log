  private async reviewVirtualCardPassed(createKybInput: CreateKybInput, cddKyb: CddKyb, user: User) {
    if (cddKyb.businessType !== ProductEnum.VirtualCard) return;
    // 判断主营业务
    const mainBusiness = createKybInput.cddKybDetails.find(item => item.key === 'mainBusiness')?.value || '';
    // 判断消费平台
    const platformOfConsumption = createKybInput.cddKybDetails.find(item => item.key === 'platformOfConsumption')?.value || '';
    //  量子卡消费目的
    const purposeOfConsumption = createKybInput.cddKybDetails.find(item => item.key === 'purposeOfConsumption')?.value || '';
    // 是否有其他消费平台
    const isOtherPlatformOfConsumption = this.isOtherValue(platformOfConsumption);
    // 是否有其他主营业务
    const isOtherMainBusiness = this.isOtherValue(mainBusiness);
    // 是否有其他量子卡消费目的
    const isOtherPurposeOfConsumption = this.isOtherValue(purposeOfConsumption);
    // 量子卡是否允许通过
    const isReviewVirtualCardPassed =
      cddKyb.businessType === ProductEnum.VirtualCard && !isOtherPlatformOfConsumption && !isOtherMainBusiness && !isOtherPurposeOfConsumption;

    if (isReviewVirtualCardPassed) {
      this.reviewKyb(user, {
        businessType: ProductEnum.VirtualCard,
        kyCaseId: cddKyb.kyCaseId,
        status: KyStatus.Passed,
        message: '',
        remarks: '量子卡KYB无(其他交易平台，其他主营业务,量子卡消费目的)自动审核通过',
        attachments: [],
      });
    }
